    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 458
        },
        "id": "3205caaa",
        "outputId": "652e9e81-6190-4a58-8c72-9bbabd98b301"
      },
      "source": [
        "# Pie Chart: Distribution of Provinces by AHH Categories\n",
        "\n",
        "# Define bins for AHH categories based on typical ranges for life expectancy\n",
        "# Using existing data to set a dynamic upper bound for the highest category\n",
        "min_ahh = df['AHH'].min()\n",
        "max_ahh = df['AHH'].max()\n",
        "\n",
        "# Let's create sensible bins. Adjust these thresholds if needed based on the data distribution.\n",
        "bins = [0, 65, 70, 75, max_ahh + 1] # Example bins: <65, 65-70, 70-75, >75\n",
        "labels = ['< 65 Tahun', '65 - 70 Tahun', '70 - 75 Tahun', '> 75 Tahun']\n",
        "\n",
        "# Create a new categorical column for AHH ranges\n",
        "df['AHH_Category'] = pd.cut(df['AHH'], bins=bins, labels=labels, right=False)\n",
        "\n",
        "# Count the number of provinces in each category\n",
        "category_counts = df['AHH_Category'].value_counts().sort_index()\n",
        "\n",
        "# Ensure all labels are present, even if count is 0\n",
        "# Reindex to ensure consistent order and handle missing categories if any\n",
        "category_counts = category_counts.reindex(labels, fill_value=0)\n",
        "\n",
        "\n",
        "# Plot the pie chart\n",
        "plt.figure(figsize=(9, 9))\n",
        "plt.pie(category_counts, labels=category_counts.index, autopct='%1.1f%%', startangle=90, counterclock=False,\n",
        "        colors=sns.color_palette('pastel')[0:len(category_counts)])\n",
        "plt.title('Distribusi Provinsi Berdasarkan Kategori Angka Harapan Hidup (AHH)', fontsize=16)\n",
        "plt.axis('equal') # Equal aspect ratio ensures that pie is drawn as a circle.\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
